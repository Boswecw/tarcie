{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tarcie",
  "version": "1.0.0",
  "identifier": "com.boswell.tarcie",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tarcie",
        "width": 480,
        "height": 140,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "globalShortcut": {
      "shortcuts": []
    }
  }
}
